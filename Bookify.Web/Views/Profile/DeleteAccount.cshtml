@model Bookify.Web.Models.DeleteAccountViewModel
@{
    ViewData["Title"] = "Xóa Tài Khoản";
    Layout = "_Layout";
    var themeColor = "#8B4513";
}

<div class="container mt-4">
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a href="/">Trang Chủ</a></li>
            <li class="breadcrumb-item"><a asp-action="Index">Hồ Sơ</a></li>
            <li class="breadcrumb-item active" aria-current="page">Xóa Tài Khoản</li>
        </ol>
    </nav>

    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow-sm border-danger">
                <div class="card-body">
                    <h4 class="text-danger"><i class="fa fa-exclamation-triangle me-2"></i>Xóa Tài Khoản</h4>
                    <p class="text-muted">
                        Hành động này sẽ <strong>xóa vĩnh viễn</strong> tài khoản và toàn bộ lịch sử đặt phòng của bạn.
                        Thao tác này <strong>không thể hoàn tác</strong>.
                    </p>

                    <form asp-action="DeleteAccount" method="post">
                        @Html.AntiForgeryToken()
                        <div class="mb-3">
                            <label class="form-label fw-semibold">Nhập mật khẩu để xác nhận</label>
                            <input asp-for="Password" type="password" class="form-control"
                                   placeholder="Mật khẩu của bạn" />
                        </div>

                        <div class="d-flex justify-content-between">
                            <a asp-action="Index" class="btn btn-outline-secondary">
                                <i class="fa fa-arrow-left me-1"></i> Hủy
                            </a>
                            <button type="submit" class="btn btn-danger">
                                <i class="fa fa-trash me-1"></i> Xóa Tài Khoản
                            </button>
                        </div>
                    </form>

                </div>
            </div>
        </div>
    </div>
</div>

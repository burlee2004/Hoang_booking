@model Bookify.Web.Models.ChangePasswordViewModel

@{
    ViewData["Title"] = "Đổi Mật Khẩu";
    Layout = "_Layout";
}

<section class="spad">
    <div class="container">
        <h2 class="text-center mb-4" style="color:#8B4513;">Đổi Mật Khẩu</h2>

        @if (TempData["SuccessMessage"] != null)
        {
            <div class="alert alert-success">@TempData["SuccessMessage"]</div>
        }
        @if (TempData["ErrorMessage"] != null)
        {
            <div class="alert alert-danger">@TempData["ErrorMessage"]</div>
        }

        <form asp-action="ChangePassword" method="post">
            @Html.AntiForgeryToken()

            <div class="mb-3">
                <label class="form-label fw-semibold">Mật Khẩu Hiện Tại</label>
                <input asp-for="CurrentPassword" type="password" class="form-control" />
                <span asp-validation-for="CurrentPassword" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label class="form-label fw-semibold">Mật Khẩu Mới</label>
                <input asp-for="NewPassword" type="password" class="form-control" id="NewPassword" />
                <span asp-validation-for="NewPassword" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label class="form-label fw-semibold">Xác Nhận Mật Khẩu Mới</label>
                <input asp-for="ConfirmNewPassword" type="password" class="form-control" />
                <span asp-validation-for="ConfirmNewPassword" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <p class="mb-2"><strong>Yêu Cầu Mật Khẩu:</strong></p>
                <ul id="passwordCriteria" class="list-unstyled small">
                    <li id="crit-length" class="text-danger">✗ Tối thiểu 6 ký tự</li>
                    <li id="crit-uppercase" class="text-danger">✗ Phải có ít nhất một chữ hoa (A-Z)</li>
                    <li id="crit-digit" class="text-danger">✗ Phải có ít nhất một chữ số (0-9)</li>
                    <li id="crit-nonalnum" class="text-danger">✗ Phải có ít nhất một ký tự đặc biệt (ví dụ: ! @@ $ %)</li>
                </ul>
            </div>

            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-primary">
                    <i class="fa fa-save me-1"></i> Đổi Mật Khẩu
                </button>
                <a asp-action="Index" class="btn btn-secondary">Hủy</a>
            </div>
        </form>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        const newPassword = document.getElementById("NewPassword");
        const critLength = document.getElementById("crit-length");
        const critUpper = document.getElementById("crit-uppercase");
        const critDigit = document.getElementById("crit-digit");
        const critNonAlnum = document.getElementById("crit-nonalnum");

        function updateCrit(el, pass) {
            el.classList.toggle("text-success", pass);
            el.classList.toggle("text-danger", !pass);
            el.textContent = (pass ? "✓ " : "✗ ") + el.textContent.substring(2);
        }

        newPassword?.addEventListener("input", function () {
            const val = this.value;
            updateCrit(critLength, val.length >= 6);
            updateCrit(critUpper, /[A-Z]/.test(val));
            updateCrit(critDigit, /\d/.test(val));
            updateCrit(critNonAlnum, /[^a-zA-Z0-9]/.test(val));
        });
    </script>
}

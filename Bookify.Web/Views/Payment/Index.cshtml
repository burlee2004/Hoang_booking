@using Bookify.Web.Models
@model List<ReservationCartItem>
@{
    ViewData["Title"] = "Thanh Toán";
    Layout = "~/Views/Shared/_Layout.cshtml";

    var total      = Model.Sum(x => x.TotalPrice());
    var itemCount  = Model.Count;
    var tax        = 5.63m;
    var finalTotal = total + tax;
}

<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />

<div class="container py-5">
    <div class="row g-4">

        <!-- ── Cột trái: Chọn phương thức ── -->
        <div class="col-lg-7">
            <div class="card shadow-sm p-4">
                <h4 class="fw-bold mb-1"><i class="fas fa-credit-card me-2 text-warning"></i>Chọn Phương Thức Thanh Toán</h4>
                <p class="text-muted small mb-4">Chọn một trong các hình thức thanh toán bên dưới</p>

                @if (TempData["ErrorMessage"] != null)
                {
                    <div class="alert alert-danger">@TempData["ErrorMessage"]</div>
                }

                <!-- ── 1. Tiền mặt ── -->
                <div class="payment-option mb-3" id="opt-cash">
                    <div class="payment-card p-3 rounded-3 border d-flex align-items-center gap-3"
                         onclick="selectMethod('cash')" style="cursor:pointer;">
                        <div class="payment-icon bg-success text-white rounded-circle d-flex align-items-center justify-content-center"
                             style="width:50px;height:50px;flex-shrink:0;">
                            <i class="fas fa-money-bill-wave fa-lg"></i>
                        </div>
                        <div class="flex-grow-1">
                            <h6 class="mb-0 fw-semibold">Thanh Toán Tại Khách Sạn</h6>
                            <small class="text-muted">Trả tiền mặt khi nhận phòng</small>
                        </div>
                        <div class="form-check mb-0">
                            <input class="form-check-input method-radio" type="radio" name="payMethod" id="r-cash" value="cash">
                        </div>
                    </div>
                    <div id="form-cash" class="method-form mt-2 d-none">
                        <form asp-action="CashPayment" method="post">
                            <button type="submit" class="btn btn-success w-100 py-2 fw-bold">
                                <i class="fas fa-check-circle me-2"></i>Xác Nhận Thanh Toán Tiền Mặt
                            </button>
                        </form>
                    </div>
                </div>

                <!-- ── 2. VNPay ── -->
                <div class="payment-option mb-3" id="opt-vnpay">
                    <div class="payment-card p-3 rounded-3 border d-flex align-items-center gap-3"
                         onclick="selectMethod('vnpay')" style="cursor:pointer;">
                        <div class="payment-icon rounded-circle overflow-hidden d-flex align-items-center justify-content-center"
                             style="width:50px;height:50px;flex-shrink:0;background:#e8f4fd;">
                            <img src="https://vnpay.vn/s1/statics/img/logo-icon.svg"
                                 onerror="this.src='https://sandbox.vnpayment.vn/paymentv2/Images/brands/logo.svg'"
                                 style="width:36px;height:36px;object-fit:contain;" alt="VNPay">
                        </div>
                        <div class="flex-grow-1">
                            <h6 class="mb-0 fw-semibold">Thanh Toán VNPay</h6>
                            <small class="text-muted">Ví điện tử, ATM, Internet Banking, QR Code</small>
                        </div>
                        <div class="form-check mb-0">
                            <input class="form-check-input method-radio" type="radio" name="payMethod" id="r-vnpay" value="vnpay">
                        </div>
                    </div>
                    <div id="form-vnpay" class="method-form mt-2 d-none">
                        <div class="alert alert-info py-2 small mb-2">
                            <i class="fas fa-info-circle me-1"></i>
                            Bạn sẽ được chuyển đến cổng thanh toán VNPay an toàn.
                            Tỷ giá quy đổi: <strong>1 USD = 24,000 VND</strong> (demo sandbox).
                        </div>
                        <form asp-action="VNPayPayment" method="post">
                            <button type="submit" class="btn w-100 py-2 fw-bold text-white" style="background:#0066cc;">
                                <i class="fas fa-external-link-alt me-2"></i>Thanh Toán Qua VNPay
                            </button>
                        </form>
                    </div>
                </div>



                <hr class="my-3">
                <a href="~/Cart/Index" class="text-muted small">
                    <i class="fas fa-arrow-left me-1"></i> Quay Lại Giỏ Hàng
                </a>
            </div>
        </div>

        <!-- ── Cột phải: Tóm tắt đơn hàng ── -->
        <div class="col-lg-5">
            <div class="card shadow-sm p-4">
                <h5 class="fw-bold mb-1">Tóm Tắt Đơn Hàng</h5>
                <p class="text-muted small mb-3">@itemCount phòng đã chọn</p>

                @foreach (var item in Model)
                {
                    <div class="d-flex align-items-center mb-3 gap-3">
                        <img src="/images/room/room-@(item.RoomId).jpg"
                             class="rounded" style="width:80px;height:55px;object-fit:cover;flex-shrink:0;"
                             alt="@item.RoomName">
                        <div class="flex-grow-1">
                            <h6 class="mb-0 fw-semibold">@item.RoomName</h6>
                            <small class="text-muted">
                                @item.CheckIn.ToString("dd/MM") → @item.CheckOut.ToString("dd/MM/yyyy")
                            </small><br>
                            <small class="text-muted">@item.Nights() đêm × $@item.PricePerNight</small>
                        </div>
                        <span class="fw-semibold text-dark">$@item.TotalPrice()</span>
                    </div>
                }

                <hr />

                <div class="d-flex justify-content-between mb-2 text-muted small">
                    <span>Tạm tính</span>
                    <span>$@total</span>
                </div>
                <div class="d-flex justify-content-between mb-2 text-muted small">
                    <span>Thuế & Phí dịch vụ</span>
                    <span>$@tax</span>
                </div>
                <div class="d-flex justify-content-between mb-3 text-muted small">
                    <span>Phí vận chuyển</span>
                    <span class="text-success fw-semibold">Miễn phí</span>
                </div>

                <hr />

                <div class="d-flex justify-content-between align-items-center">
                    <h5 class="mb-0 fw-bold">Tổng Cộng</h5>
                    <h5 class="mb-0 fw-bold text-danger">$@finalTotal</h5>
                </div>

                <div class="mt-3 p-2 rounded-2 text-center" style="background:#f8f9fa;">
                    <small class="text-muted">
                        <i class="fas fa-shield-alt text-success me-1"></i>
                        Thanh toán được bảo mật và mã hóa SSL
                    </small>
                </div>
            </div>
        </div>

    </div>
</div>

<style>
    .payment-card {
        transition: all 0.25s ease;
        background: #fff;
    }
    .payment-card:hover {
        border-color: #8B4513 !important;
        background: #fdf8f5;
        transform: translateX(3px);
    }
    .payment-card.selected {
        border-color: #8B4513 !important;
        background: #fdf8f5;
        box-shadow: 0 0 0 2px rgba(139,69,19,0.15);
    }
    .method-form {
        animation: fadeIn 0.2s ease;
    }
    @@keyframes fadeIn {
        from { opacity: 0; transform: translateY(-5px); }
        to   { opacity: 1; transform: translateY(0); }
    }
</style>

@section Scripts {
<script>
    function selectMethod(method) {
        // Bỏ chọn tất cả
        document.querySelectorAll('.payment-card').forEach(c => c.classList.remove('selected'));
        document.querySelectorAll('.method-form').forEach(f => f.classList.add('d-none'));
        document.querySelectorAll('.method-radio').forEach(r => r.checked = false);

        // Chọn method được click
        document.querySelector(`#opt-${method} .payment-card`).classList.add('selected');
        document.querySelector(`#form-${method}`).classList.remove('d-none');
        document.querySelector(`#r-${method}`).checked = true;
    }
</script>
}

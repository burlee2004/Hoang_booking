@{
    ViewData["Title"] = "Giới Thiệu";
}

<!-- Breadcrumb Section Begin -->
<div class="breadcrumb-section">
    <div class="container">
        <div class="row">
            <div class="col-lg-12">
                <div class="breadcrumb-text">
                    <h2>Giới Thiệu</h2>
                    <div class="bt-option">
                        <a asp-controller="Home" asp-action="Index">Trang Chủ</a>
                        <span>Giới Thiệu</span>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
<!-- Breadcrumb Section End -->

<!-- About Us Page Section Begin -->
<section class="aboutus-page-section spad">
    <div class="container">
        <div class="about-page-text">
            <div class="row">
                <div class="col-lg-6">
                    <div class="ap-title">
                        <h2>Chào Mừng Đến Với Nile Horizon.</h2>
                        <p>
                            Được xây dựng năm 2025, khách sạn tọa lạc tại trung tâm Cairo,
                            với khả năng tiếp cận dễ dàng đến các điểm tham quan du lịch của thành phố.
                            Chúng tôi cung cấp các phòng được trang trí tinh tế và dịch vụ đẳng cấp.
                        </p>
                    </div>
                </div>
                <div class="col-lg-5 offset-lg-1">
                    <ul class="ap-services">
                        <li><i class="icon_check"></i> Giảm 20% Chi Phí Lưu Trú</li>
                        <li><i class="icon_check"></i> Bữa Sáng Miễn Phí Hàng Ngày</li>
                        <li><i class="icon_check"></i> Giặt Ủi 3 Bộ/Ngày</li>
                        <li><i class="icon_check"></i> Wifi Miễn Phí</li>
                        <li><i class="icon_check"></i> Giảm 20% Dịch Vụ Ăn Uống</li>
                    </ul>
                </div>
            </div>
        </div>
        <div class="about-page-services">
            <div class="row">
                <div class="col-md-4">
                    <div class="ap-service-item set-bg" data-setbg="@Url.Content("~/images/about/about-p1.jpg")">
                        <div class="api-text">
                            <h3>Dịch Vụ Nhà Hàng</h3>
                        </div>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="ap-service-item set-bg" data-setbg="@Url.Content("~/images/about/about-p2.jpg")">
                        <div class="api-text">
                            <h3>Du Lịch & Cắm Trại</h3>
                        </div>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="ap-service-item set-bg" data-setbg="@Url.Content("~/images/about/about-p3.jpg")">
                        <div class="api-text">
                            <h3>Sự Kiện & Tiệc</h3>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
<!-- About Us Page Section End -->

<!-- Video Section Begin -->
<section class="video-section set-bg" data-setbg="@Url.Content("~/images/video-bg.jpg")">
    <div class="container">
        <div class="row">
            <div class="col-lg-12">
                <div class="video-text">
                    <h2>Khám Phá Khách Sạn & Dịch Vụ Của Chúng Tôi.</h2>
                    <p>Trải nghiệm kỳ nghỉ tuyệt vời tại Nile Horizon — nơi mọi khoảnh khắc đều đáng nhớ</p>
                    <a href="https://www.youtube.com/watch?v=s735gqF_cfc" class="play-btn video-popup">
                        <img src="~/images/play.png" alt="Xem video">
                    </a>
                </div>
            </div>
        </div>
    </div>
</section>
<!-- Video Section End -->

<!-- Gallery Section Begin -->
<section class="gallery-section spad">
    <div class="container">
        <div class="row">
            <div class="col-lg-12">
                <div class="section-title">
                    <span>Thư Viện Ảnh</span>
                    <h2>Khám Phá Không Gian</h2>
                </div>
            </div>
        </div>
        <div class="row">
            <div class="col-lg-6">
                <div class="gallery-item set-bg" data-setbg="@Url.Content("~/images/gallery/gallery-1.jpg")">
                    <div class="gi-text">
                        <h3>Phòng Sang Trọng</h3>
                    </div>
                </div>
                <div class="row">
                    <div class="col-sm-6">
                        <div class="gallery-item set-bg" data-setbg="@Url.Content("~/images/gallery/gallery-3.jpg")">
                            <div class="gi-text">
                                <h3>Phòng Sang Trọng</h3>
                            </div>
                        </div>
                    </div>
                    <div class="col-sm-6">
                        <div class="gallery-item set-bg" data-setbg="@Url.Content("~/images/gallery/gallery-4.jpg")">
                            <div class="gi-text">
                                <h3>Phòng Sang Trọng</h3>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-lg-6">
                <div class="gallery-item large-item set-bg" data-setbg="@Url.Content("~/images/gallery/gallery-2.jpg")">
                    <div class="gi-text">
                        <h3>Phòng Sang Trọng</h3>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
<!-- Gallery Section End -->

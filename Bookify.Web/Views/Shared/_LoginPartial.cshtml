@using Microsoft.AspNetCore.Identity

@inject SignInManager<IdentityUser> SignInManager
@inject UserManager<IdentityUser> UserManager

<ul class="navbar-nav d-flex flex-row gap-2 align-items-center mb-0 list-unstyled">
    @if (SignInManager.IsSignedIn(User))
    {
        <li class="nav-item">
            <a id="manage" class="nav-link text-dark fw-medium" asp-area="Identity" asp-page="/Account/Manage/Index" title="Manage">
                <i class="fa fa-smile-o me-1"></i> Xin chào, @UserManager.GetUserName(User)!
            </a>
        </li>
        <li class="nav-item">
            <form id="logoutForm" class="form-inline m-0" asp-area="Identity" asp-page="/Account/Logout" asp-route-returnUrl="@Url.Action("Index", "Home", new { area = "" })">
                <button id="logout" type="submit" class="btn btn-outline-danger btn-sm rounded-pill px-3 fw-bold shadow-sm">
                    <i class="fa fa-sign-out"></i> Đăng Xuất
                </button>
            </form>
        </li>
    }
    else
    {
        <li class="nav-item">
            <a class="btn btn-outline-primary btn-sm rounded-pill px-4 fw-bold shadow-sm" id="login" asp-area="Identity" asp-page="/Account/Login">
                Đăng Nhập
            </a>
        </li>
        <li class="nav-item">
            <a class="btn btn-primary btn-sm rounded-pill px-4 fw-bold text-white shadow-sm" id="register" asp-area="Identity" asp-page="/Account/Register">
                Đăng Ký
            </a>
        </li>
    }
</ul>
@model Bookify.Web.Models.ContactViewModel
@{
    ViewData["Title"] = "Liên Hệ";
    bool isAuth = User.Identity?.IsAuthenticated == true;
    bool isPrefilled = isAuth && !string.IsNullOrEmpty(Model?.FullName);
}

<div class="breadcrumb-section">
    <div class="container">
        <div class="row">
            <div class="col-lg-12">
                <div class="breadcrumb-text">
                    <h2>Liên Hệ</h2>
                    <div class="bt-option">
                        <a asp-controller="Home" asp-action="Index">Trang Chủ</a>
                        <span>Liên Hệ</span>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<section class="contact-section spad">
    <div class="container">
        <div class="row">
            <div class="col-lg-4">
                <div class="contact-text">
                    <h2>Thông Tin Liên Hệ</h2>
                    <p>Để biết thêm thông tin hoặc có bất kỳ thắc mắc nào, vui lòng liên hệ với chúng tôi.</p>
                    <table>
                        <tbody>
                            <tr><td class="c-o">Địa Chỉ:</td><td>Thủ Dầu Một, Bình Dương</td></tr>
                            <tr><td class="c-o">Điện Thoại:</td><td> 034 779 3976</td></tr>
                            <tr><td class="c-o">Email:</td><td> hoanglubo2004@gmail.com</td></tr>
                        </tbody>
                    </table>
                </div>
            </div>

            <div class="col-lg-7 offset-lg-1">
                @if (TempData["ContactSuccess"] != null)
                {
                    <div class="alert alert-success rounded-3 mb-3">
                        <i class="fa fa-check-circle me-2"></i>@TempData["ContactSuccess"]
                    </div>
                }

                @if (isAuth)
                {
                    <div class="alert mb-3 rounded-3" style="background:#fdf6ee;border:1px solid #e8d5b7;color:#8B4513;font-size:0.85rem;">
                        <i class="fa fa-user-circle me-2"></i>Đang gửi với tư cách: <strong>@User.Identity!.Name</strong>
                    </div>
                }

                <form asp-controller="Contact" asp-action="Contact" method="post" class="contact-form">
                    @Html.AntiForgeryToken()
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-2 small"></div>
                    <div class="row">
                        <div class="col-lg-6">
                            @if (isPrefilled)
                            {
                                <input asp-for="FullName" placeholder="Họ và Tên *" class="prefilled" />
                            }
                            else
                            {
                                <input asp-for="FullName" placeholder="Họ và Tên *" />
                            }
                            <span asp-validation-for="FullName" class="text-danger small"></span>
                        </div>
                        <div class="col-lg-6">
                            @if (isAuth)
                            {
                                <input asp-for="Email" type="email" placeholder="Email *" class="prefilled" readonly="readonly" />
                            }
                            else
                            {
                                <input asp-for="Email" type="email" placeholder="Email *" />
                            }
                            <span asp-validation-for="Email" class="text-danger small"></span>
                        </div>
                        <div class="col-lg-12">
                            <textarea asp-for="Message" placeholder="Nội dung tin nhắn *" rows="5"></textarea>
                            <span asp-validation-for="Message" class="text-danger small d-block mb-2"></span>
                            <button type="submit"><i class="fa fa-paper-plane me-2"></i>Gửi Tin Nhắn</button>
                        </div>
                    </div>
                </form>
            </div>
        </div>

       
    </div>
</section>

<style>
    .contact-form input.prefilled { background:#fdf8f3!important; border-color:#c8963e!important; color:#5a3010!important; font-weight:500; }
</style>

@section Scripts { <partial name="_ValidationScriptsPartial" /> }

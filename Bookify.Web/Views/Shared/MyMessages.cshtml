@model IEnumerable<Bookify.Data.Models.ContactMessage>
@{
    ViewData["Title"] = "Tin Nhắn Của Tôi";
    Layout = "_Layout";
}

<div class="breadcrumb-section">
    <div class="container">
        <div class="breadcrumb-text">
            <h2>Tin Nhắn Của Tôi</h2>
            <div class="bt-option">
                <a asp-controller="Home" asp-action="Index">Trang Chủ</a>
                <span>Hộp Thư</span>
            </div>
        </div>
    </div>
</div>

<section class="spad" style="background:#f4f6f9;min-height:60vh;">
    <div class="container">
        <div class="d-flex align-items-center justify-content-between mb-4 flex-wrap gap-3">
            <h4 class="fw-bold mb-0" style="color:#1a1a2e;">
                <i class="fa fa-envelope me-2" style="color:#c8963e;"></i>Lịch Sử Liên Hệ
            </h4>
            <a asp-controller="Contact" asp-action="Contact"
               style="background:linear-gradient(135deg,#8B4513,#c8963e);color:#fff;padding:9px 20px;border-radius:10px;font-size:.85rem;font-weight:600;text-decoration:none;">
                <i class="fa fa-plus me-1"></i> Gửi Tin Nhắn Mới
            </a>
        </div>

        @if (!Model.Any())
        {
            <div style="text-align:center;padding:60px 20px;color:#aaa;background:#fff;border-radius:16px;">
                <i class="fa fa-inbox" style="font-size:3rem;display:block;margin-bottom:16px;"></i>
                <p class="fw-semibold">Bạn chưa gửi tin nhắn nào</p>
                <a asp-controller="Contact" asp-action="Contact" class="btn btn-outline-secondary mt-2">Liên Hệ Ngay</a>
            </div>
        }
        else
        {
            foreach (var m in Model)
            {
                <div style="background:#fff;border-radius:16px;padding:24px 28px;margin-bottom:20px;box-shadow:0 2px 12px rgba(0,0,0,.06);border:1px solid #eee;@(!m.IsRead && m.AdminReply != null ? "border-left:3px solid #c8963e;" : "")">
                    <div class="d-flex justify-content-between align-items-start flex-wrap gap-2 mb-3">
                        <div>
                            <span style="font-size:.75rem;color:#999;">@m.SentAt.ToString("dd/MM/yyyy HH:mm")</span>
                            @if (!m.IsRead && m.AdminReply != null)
                            {
                                <span style="background:#fff8e1;color:#f59e0b;border:1px solid #fde68a;padding:2px 10px;border-radius:20px;font-size:.72rem;font-weight:600;margin-left:8px;">
                                    Phản hồi mới!
                                </span>
                            }
                        </div>
                        @if (m.AdminReply != null)
                        {
                            <span style="background:#ecfdf5;color:#059669;border:1px solid #a7f3d0;padding:4px 12px;border-radius:20px;font-size:.75rem;font-weight:600;">
                                <i class="fa fa-check me-1"></i>Đã được phản hồi
                            </span>
                        }
                        else
                        {
                            <span style="background:#f3f4f6;color:#6b7280;border:1px solid #e5e7eb;padding:4px 12px;border-radius:20px;font-size:.75rem;font-weight:600;">
                                <i class="fa fa-clock-o me-1"></i>Chờ phản hồi
                            </span>
                        }
                    </div>

                    <!-- Tin nhắn của user -->
                    <div style="background:#fdf8f3;border-radius:10px;padding:14px 18px;margin-bottom:12px;">
                        <div style="font-size:.75rem;color:#c8963e;font-weight:600;margin-bottom:6px;text-transform:uppercase;letter-spacing:.5px;">
                            <i class="fa fa-user me-1"></i>Tin nhắn của bạn
                        </div>
                        <p style="margin:0;color:#444;line-height:1.7;font-size:.9rem;">@m.Message</p>
                    </div>

                    <!-- Phản hồi từ admin -->
                    @if (!string.IsNullOrEmpty(m.AdminReply))
                    {
                        <div style="background:#ecfdf5;border-radius:10px;padding:14px 18px;border-left:3px solid #059669;">
                            <div style="font-size:.75rem;color:#059669;font-weight:600;margin-bottom:6px;text-transform:uppercase;letter-spacing:.5px;">
                                <i class="fa fa-reply me-1"></i>Phản hồi từ Nile Horizon
                                <span style="color:#aaa;font-weight:400;margin-left:8px;">@m.RepliedAt?.ToString("dd/MM/yyyy HH:mm")</span>
                            </div>
                            <p style="margin:0;color:#065f46;line-height:1.7;font-size:.9rem;">@m.AdminReply</p>
                        </div>
                    }
                </div>
            }
        }
    </div>
</section>

@using Bookify.Web.Models
@model List<ReservationCartItem>

@{
    ViewData["Title"] = "Giỏ Hàng";
    Layout = "~/Views/Shared/_Layout.cshtml";

    var cartItems = Model;
    int cartCount = cartItems.Count;
    decimal totalPrice = cartItems.Sum(i => i.TotalPrice());
}

<section class="h-100 h-custom" style="background-color: #f5f5f5;">
    <div class="container py-5 h-100">
        <div class="row d-flex justify-content-center align-items-center h-100">
            <div class="col-12">
                <div class="card card-registration" style="border-radius: 15px;">
                    <div class="card-body p-0">
                        <div class="row g-0">

                            <!-- Danh sách phòng -->
                            <div class="col-lg-8">
                                <div class="p-5">

                                    <div class="d-flex justify-content-between align-items-center mb-5">
                                        <h1 class="fw-bold mb-0">Giỏ Hàng</h1>
                                        <h6 class="mb-0 text-muted">@cartCount phòng</h6>
                                    </div>

                                    <hr class="my-4">

                                    @if (cartItems.Any())
                                    {
                                        foreach (var item in cartItems)
                                        {
                                            <div class="row mb-4 d-flex justify-content-between align-items-center">

                                                <!-- Ảnh phòng -->
                                                <div class="col-md-2">
                                                    <img src="/images/room/room-@(item.RoomId).jpg" class="img-fluid rounded-3" alt="@item.RoomName" />
                                                </div>

                                                <!-- Thông tin phòng -->
                                                <div class="col-md-3">
                                                    <h6 class="text-muted">Phòng</h6>
                                                    <h6 class="mb-0">@item.RoomName</h6>
                                                    <small>@item.CheckIn.ToString("dd MMM") → @item.CheckOut.ToString("dd MMM")</small>
                                                    <br />
                                                    <small class="text-muted">Số đêm: @item.Nights()</small>
                                                </div>

                                                <!-- Điều chỉnh số lượng -->
                                                <div class="col-md-3 d-flex align-items-center">

                                                    <form asp-controller="Cart" asp-action="Decrease" method="post">
                                                        <input type="hidden" name="roomId" value="@item.RoomId" />
                                                        <input type="hidden" name="checkIn" value="@item.CheckIn.ToString("o")" />
                                                        <input type="hidden" name="checkOut" value="@item.CheckOut.ToString("o")" />
                                                        <button class="btn btn-outline-secondary">-</button>
                                                    </form>

                                                    <span class="mx-3">@item.Quantity</span>

                                                    <form asp-controller="Cart" asp-action="Increase" method="post">
                                                        <input type="hidden" name="roomId" value="@item.RoomId" />
                                                        <input type="hidden" name="checkIn" value="@item.CheckIn.ToString("o")" />
                                                        <input type="hidden" name="checkOut" value="@item.CheckOut.ToString("o")" />
                                                        <button class="btn btn-outline-secondary">+</button>
                                                    </form>

                                                </div>

                                                <!-- Tổng tiền -->
                                                <div class="col-md-2">
                                                    <h6>$@item.TotalPrice()</h6>
                                                </div>

                                                <!-- Xóa -->
                                                <div class="col-md-1 text-end">
                                                    <form asp-controller="Cart" asp-action="Remove" method="post">
                                                        <input type="hidden" name="roomId" value="@item.RoomId" />
                                                        <input type="hidden" name="checkIn" value="@item.CheckIn.ToString("o")" />
                                                        <input type="hidden" name="checkOut" value="@item.CheckOut.ToString("o")" />
                                                        <button class="btn btn-outline-danger" title="Xóa">×</button>
                                                    </form>
                                                </div>

                                            </div>

                                            <hr class="my-4" />
                                        }
                                    }
                                    else
                                    {
                                        <div class="text-center py-4">
                                            <i class="fa fa-shopping-cart fa-3x text-muted mb-3"></i>
                                            <p class="text-muted fs-5">Giỏ hàng của bạn đang trống.</p>
                                            <a href="~/Room/Rooms" class="btn btn-outline-dark mt-2">Xem Danh Sách Phòng</a>
                                        </div>
                                    }

                                    <div class="pt-5">
                                        <a href="~/Home/Index" class="btn btn-outline-dark btn-lg">← Về Trang Chủ</a>
                                    </div>

                                </div>
                            </div>

                            <!-- Tóm tắt đơn hàng -->
                            <div class="col-lg-4 bg-light">
                                <div class="p-5">

                                    <h3 class="fw-bold mb-5 mt-2 pt-1">Tóm Tắt</h3>

                                    <hr class="my-4">

                                    <div class="d-flex justify-content-between mb-4">
                                        <h5 class="text-uppercase">Số Phòng</h5>
                                        <h5>@cartCount</h5>
                                    </div>

                                    <div class="d-flex justify-content-between mb-4">
                                        <h5>Tổng Cộng</h5>
                                        <h5>$@totalPrice</h5>
                                    </div>

                                    @if (cartItems.Any())
                                    {
                                        <form method="get" asp-controller="Payment" asp-action="Index">
                                            <button type="submit" class="btn btn-gradient btn-lg w-100">Tiến Hành Thanh Toán</button>
                                        </form>
                                    }

                                </div>
                            </div>

                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<style>
    .btn-gradient {
        background: linear-gradient(135deg, #f59e0b, #d97706);
        color: white;
        border: none;
        transition: all 0.3s ease;
    }

        .btn-gradient:hover {
            background: linear-gradient(135deg, #d97706, #b45309);
            transform: translateY(-2px);
            box-shadow: 0 5px 15px rgba(0,0,0,0.2);
        }
</style>

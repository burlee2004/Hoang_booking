@model IEnumerable<Bookify.Data.Models.ContactMessage>
@{
    ViewData["Title"] = "Quản Lý Liên Hệ";
    Layout = "_Layout";
    int unread = Model.Count(m => !m.IsRead);
    int total  = Model.Count();
}

<style>
    .cm-wrap { background:#f4f6f9; min-height:100vh; padding:32px 0 60px; }
    .cm-card { background:#fff; border-radius:18px; box-shadow:0 2px 16px rgba(0,0,0,.07); border:1px solid #eee; overflow:hidden; }
    .cm-card-header { padding:18px 28px; border-bottom:1px solid #f0ece6; display:flex; align-items:center; justify-content:space-between; flex-wrap:wrap; gap:10px; }
    .cm-card-header h5 { margin:0; font-weight:700; color:#1a1a2e; }
    .stat-pill { display:inline-flex; align-items:center; gap:6px; padding:5px 14px; border-radius:20px; font-size:.8rem; font-weight:600; }
    .msg-row { border-bottom:1px solid #f5f5f5; transition:background .15s; }
    .msg-row:hover { background:#fdf8f4; }
    .msg-row.unread { border-left:3px solid #c8963e; }
    .msg-row td { padding:14px 18px; vertical-align:top; font-size:.87rem; color:#444; }
    .msg-name { font-weight:700; color:#1a1a2e; }
    .msg-email { font-size:.78rem; color:#888; }
    .msg-text { color:#555; line-height:1.6; max-width:320px; }
    .msg-reply { background:#ecfdf5; border-left:3px solid #059669; padding:8px 12px; border-radius:6px; font-size:.82rem; color:#065f46; margin-top:6px; }
    .btn-sm-act { display:inline-flex; align-items:center; gap:4px; padding:5px 11px; border-radius:7px; font-size:.77rem; font-weight:600; border:none; cursor:pointer; text-decoration:none; transition:all .2s; }
    .btn-sm-act:hover { transform:translateY(-1px); }
    .btn-reply  { background:#eff6ff; color:#3b82f6; }
    .btn-delete { background:#fef2f2; color:#dc2626; }
    .btn-read   { background:#f3f4f6; color:#6b7280; }
    .reply-modal { display:none; position:fixed; inset:0; background:rgba(0,0,0,.45); z-index:9999; align-items:center; justify-content:center; }
    .reply-modal.open { display:flex; }
    .reply-box { background:#fff; border-radius:20px; padding:32px; width:100%; max-width:520px; box-shadow:0 20px 60px rgba(0,0,0,.2); }
    .reply-box h5 { font-weight:700; color:#1a1a2e; margin-bottom:4px; }
    .reply-box textarea { width:100%; border:1.5px solid #e0d5c5; border-radius:10px; padding:12px; font-size:.9rem; resize:vertical; min-height:120px; outline:none; font-family:inherit; }
    .reply-box textarea:focus { border-color:#c8963e; box-shadow:0 0 0 3px rgba(200,150,62,.12); }
    .btn-send { background:linear-gradient(135deg,#8B4513,#c8963e); color:#fff; border:none; padding:11px 28px; border-radius:10px; font-weight:700; cursor:pointer; transition:all .3s; }
    .btn-send:hover { transform:translateY(-2px); box-shadow:0 6px 20px rgba(139,69,19,.3); }
    .btn-cancel { background:#f3f4f6; color:#555; border:none; padding:11px 20px; border-radius:10px; font-weight:600; cursor:pointer; margin-right:8px; }
    .unread-dot { width:8px; height:8px; background:#c8963e; border-radius:50%; display:inline-block; margin-right:4px; }
</style>

<div class="cm-wrap">
    <div class="container">

        <!-- Header -->
        <div class="d-flex align-items-center justify-content-between mb-4 flex-wrap gap-3">
            <div>
                <h3 class="mb-1 fw-bold" style="color:#1a1a2e;">
                    <i class="fa fa-envelope me-2" style="color:#c8963e;"></i>Quản Lý Liên Hệ
                </h3>
                <p class="text-muted mb-0" style="font-size:.85rem;">Tin nhắn từ khách hàng</p>
            </div>
            <a asp-controller="Admin" asp-action="Index"
               style="background:#f4f6f9;color:#555;padding:9px 18px;border-radius:10px;font-size:.85rem;font-weight:600;text-decoration:none;border:1px solid #e5e7eb;">
                <i class="fa fa-arrow-left me-1"></i> Bảng Điều Khiển
            </a>
        </div>

        @if (TempData["Success"] != null)
        {
            <div class="alert alert-success rounded-3 mb-3"><i class="fa fa-check-circle me-2"></i>@TempData["Success"]</div>
        }

        <!-- Stats -->
        <div class="row g-3 mb-4">
            <div class="col-6 col-md-3">
                <div style="background:#fff;border-radius:14px;padding:18px 20px;box-shadow:0 2px 10px rgba(0,0,0,.06);border:1px solid #eee;display:flex;align-items:center;gap:14px;">
                    <div style="width:46px;height:46px;background:#eff6ff;border-radius:12px;display:flex;align-items:center;justify-content:center;">
                        <i class="fa fa-envelope" style="color:#3b82f6;font-size:1.2rem;"></i>
                    </div>
                    <div>
                        <div style="font-size:1.6rem;font-weight:800;color:#1a1a2e;line-height:1;">@total</div>
                        <div style="font-size:.75rem;color:#999;text-transform:uppercase;letter-spacing:.5px;">Tổng Tin Nhắn</div>
                    </div>
                </div>
            </div>
            <div class="col-6 col-md-3">
                <div style="background:#fff;border-radius:14px;padding:18px 20px;box-shadow:0 2px 10px rgba(0,0,0,.06);border:1px solid #eee;display:flex;align-items:center;gap:14px;">
                    <div style="width:46px;height:46px;background:#fff8e1;border-radius:12px;display:flex;align-items:center;justify-content:center;">
                        <i class="fa fa-envelope-o" style="color:#f59e0b;font-size:1.2rem;"></i>
                    </div>
                    <div>
                        <div style="font-size:1.6rem;font-weight:800;color:#1a1a2e;line-height:1;">@unread</div>
                        <div style="font-size:.75rem;color:#999;text-transform:uppercase;letter-spacing:.5px;">Chưa Đọc</div>
                    </div>
                </div>
            </div>
            <div class="col-6 col-md-3">
                <div style="background:#fff;border-radius:14px;padding:18px 20px;box-shadow:0 2px 10px rgba(0,0,0,.06);border:1px solid #eee;display:flex;align-items:center;gap:14px;">
                    <div style="width:46px;height:46px;background:#ecfdf5;border-radius:12px;display:flex;align-items:center;justify-content:center;">
                        <i class="fa fa-reply" style="color:#059669;font-size:1.2rem;"></i>
                    </div>
                    <div>
                        <div style="font-size:1.6rem;font-weight:800;color:#1a1a2e;line-height:1;">@Model.Count(m => m.AdminReply != null)</div>
                        <div style="font-size:.75rem;color:#999;text-transform:uppercase;letter-spacing:.5px;">Đã Phản Hồi</div>
                    </div>
                </div>
            </div>
            <div class="col-6 col-md-3">
                <div style="background:#fff;border-radius:14px;padding:18px 20px;box-shadow:0 2px 10px rgba(0,0,0,.06);border:1px solid #eee;display:flex;align-items:center;gap:14px;">
                    <div style="width:46px;height:46px;background:#fdf6ee;border-radius:12px;display:flex;align-items:center;justify-content:center;">
                        <i class="fa fa-check-circle" style="color:#c8963e;font-size:1.2rem;"></i>
                    </div>
                    <div>
                        <div style="font-size:1.6rem;font-weight:800;color:#1a1a2e;line-height:1;">@Model.Count(m => m.IsRead)</div>
                        <div style="font-size:.75rem;color:#999;text-transform:uppercase;letter-spacing:.5px;">Đã Đọc</div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Table -->
        <div class="cm-card">
            <div class="cm-card-header">
                <h5><i class="fa fa-inbox me-2" style="color:#8B4513;"></i>Hộp Thư Đến</h5>
                @if (unread > 0)
                {
                    <span class="stat-pill" style="background:#fff8e1;color:#f59e0b;border:1px solid #fde68a;">
                        <span class="unread-dot"></span>@unread tin chưa đọc
                    </span>
                }
            </div>

            @if (!Model.Any())
            {
                <div style="text-align:center;padding:60px 20px;color:#aaa;">
                    <i class="fa fa-inbox" style="font-size:3rem;display:block;margin-bottom:16px;"></i>
                    <p class="fw-semibold mb-1">Chưa có tin nhắn nào</p>
                </div>
            }
            else
            {
                <div class="table-responsive">
                    <table style="width:100%;border-collapse:collapse;">
                        <thead>
                            <tr style="background:linear-gradient(135deg,#8B4513,#a0522d);">
                                <th style="color:#fff;font-size:.77rem;font-weight:600;text-transform:uppercase;letter-spacing:.8px;padding:13px 18px;">Người Gửi</th>
                                <th style="color:#fff;font-size:.77rem;font-weight:600;text-transform:uppercase;letter-spacing:.8px;padding:13px 18px;">Nội Dung</th>
                                <th style="color:#fff;font-size:.77rem;font-weight:600;text-transform:uppercase;letter-spacing:.8px;padding:13px 18px;">Thời Gian</th>
                                <th style="color:#fff;font-size:.77rem;font-weight:600;text-transform:uppercase;letter-spacing:.8px;padding:13px 18px;">Trạng Thái</th>
                                <th style="color:#fff;font-size:.77rem;font-weight:600;text-transform:uppercase;letter-spacing:.8px;padding:13px 18px;">Thao Tác</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var m in Model)
                            {
                                <tr class="msg-row @(!m.IsRead ? "unread" : "")">
                                    <td>
                                        @if (!m.IsRead) { <span class="unread-dot"></span> }
                                        <div class="msg-name">@m.FullName</div>
                                        <div class="msg-email">@m.Email</div>
                                    </td>
                                    <td>
                                        <div class="msg-text">@m.Message</div>
                                        @if (!string.IsNullOrEmpty(m.AdminReply))
                                        {
                                            <div class="msg-reply">
                                                <i class="fa fa-reply me-1"></i><strong>Phản hồi:</strong> @m.AdminReply
                                                <div style="font-size:.72rem;color:#888;margin-top:2px;">@m.RepliedAt?.ToString("dd/MM/yyyy HH:mm")</div>
                                            </div>
                                        }
                                    </td>
                                    <td style="white-space:nowrap;">
                                        <div style="font-weight:600;color:#333;font-size:.82rem;">@m.SentAt.ToString("dd/MM/yyyy")</div>
                                        <div style="font-size:.75rem;color:#aaa;">@m.SentAt.ToString("HH:mm")</div>
                                    </td>
                                    <td>
                                        @if (!string.IsNullOrEmpty(m.AdminReply))
                                        {
                                            <span style="background:#ecfdf5;color:#059669;border:1px solid #a7f3d0;padding:4px 10px;border-radius:20px;font-size:.75rem;font-weight:600;">
                                                <i class="fa fa-check me-1"></i>Đã phản hồi
                                            </span>
                                        }
                                        else if (m.IsRead)
                                        {
                                            <span style="background:#f3f4f6;color:#6b7280;border:1px solid #e5e7eb;padding:4px 10px;border-radius:20px;font-size:.75rem;font-weight:600;">
                                                <i class="fa fa-eye me-1"></i>Đã đọc
                                            </span>
                                        }
                                        else
                                        {
                                            <span style="background:#fff8e1;color:#f59e0b;border:1px solid #fde68a;padding:4px 10px;border-radius:20px;font-size:.75rem;font-weight:600;">
                                                <i class="fa fa-circle me-1" style="font-size:.5rem;"></i>Chưa đọc
                                            </span>
                                        }
                                    </td>
                                    <td>
                                        <div style="display:flex;gap:6px;flex-wrap:wrap;">
                                            <button class="btn-sm-act btn-reply"
                                                    onclick="openReply(@m.Id, '@Html.Raw(m.FullName)', '@Html.Raw(m.Email)', '@Html.Raw((m.AdminReply ?? "").Replace("'","\\'"  ))')">
                                                <i class="fa fa-reply"></i> Phản Hồi
                                            </button>
                                            @if (!m.IsRead)
                                            {
                                                <form asp-action="MarkRead" asp-route-id="@m.Id" method="post" style="display:inline;">
                                                    @Html.AntiForgeryToken()
                                                    <button type="submit" class="btn-sm-act btn-read">
                                                        <i class="fa fa-eye"></i> Đọc
                                                    </button>
                                                </form>
                                            }
                                            <form asp-action="Delete" asp-route-id="@m.Id" method="post" style="display:inline;">
                                                @Html.AntiForgeryToken()
                                                <button type="submit" class="btn-sm-act btn-delete"
                                                        onclick="return confirm('Xóa tin nhắn này?')">
                                                    <i class="fa fa-trash"></i>
                                                </button>
                                            </form>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>
</div>

<!-- Reply Modal -->
<div class="reply-modal" id="replyModal">
    <div class="reply-box">
        <h5><i class="fa fa-reply me-2" style="color:#c8963e;"></i>Phản Hồi Tin Nhắn</h5>
        <p class="text-muted mb-3" style="font-size:.85rem;" id="replyTo"></p>
        <form asp-action="Reply" method="post" id="replyForm">
            @Html.AntiForgeryToken()
            <input type="hidden" name="id" id="replyId" />
            <textarea name="replyText" id="replyText" placeholder="Nhập nội dung phản hồi..."></textarea>
            <div class="d-flex justify-content-end mt-3 gap-2">
                <button type="button" class="btn-cancel" onclick="closeReply()">Hủy</button>
                <button type="submit" class="btn-send"><i class="fa fa-paper-plane me-2"></i>Gửi Phản Hồi</button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
<script>
    function openReply(id, name, email, existing) {
        document.getElementById('replyId').value = id;
        document.getElementById('replyTo').textContent = 'Gửi đến: ' + name + ' (' + email + ')';
        document.getElementById('replyText').value = existing || '';
        document.getElementById('replyModal').classList.add('open');
        document.getElementById('replyText').focus();
    }
    function closeReply() {
        document.getElementById('replyModal').classList.remove('open');
    }
    document.getElementById('replyModal').addEventListener('click', function(e) {
        if (e.target === this) closeReply();
    });
</script>
}
